<mxfile host="Electron">
  <diagram name="Class Diagram" id="classes">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="legend" value="Class Diagram — Lexis" style="text;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="10" width="300" height="30" as="geometry"/></mxCell>

        <!-- ====== User ====== -->
        <mxCell id="cls-user" value="&lt;b&gt;User&lt;/b&gt;" style="swimlane;fillColor=#7c3aed;fontColor=#fff;startSize=28;" vertex="1" parent="1"><mxGeometry x="20" y="60" width="220" height="180" as="geometry"/></mxCell>
        <mxCell id="fu1" value="+ id, name, email, password&#xa;+ isAdmin, isAnonymous&#xa;+ xp, coins, level, currentTitle&#xa;+ streak, longestStreak, lastActiveDate&#xa;+ solvedSheets[], hardcoreBest&#xa;+ avatar{}, purchasedStoreItems[]&#xa;+ theme, adaptText" style="text;align=left;spacingLeft=8;" vertex="1" parent="cls-user"><mxGeometry y="28" width="220" height="152" as="geometry"/></mxCell>

        <!-- ====== SessionModel ====== -->
        <mxCell id="cls-session" value="&lt;b&gt;SessionModel&lt;/b&gt;" style="swimlane;fillColor=#dc2626;fontColor=#fff;startSize=28;" vertex="1" parent="1"><mxGeometry x="20" y="280" width="220" height="260" as="geometry"/></mxCell>
        <mxCell id="fs1" value="- users[], session&#xa;- USERS_KEY, SESSION_KEY" style="text;align=left;spacingLeft=8;" vertex="1" parent="cls-session"><mxGeometry y="28" width="220" height="30" as="geometry"/></mxCell>
        <mxCell id="ms1" value="+ initSession()&#xa;+ startAnonymousSession()&#xa;+ getSession()&#xa;+ login(id, pw)&#xa;+ createAccount()&#xa;+ convertGuestToAccount()&#xa;+ updateUser(user)&#xa;+ recordDailyActivity()&#xa;+ getAllUsers()&#xa;+ deleteUser(id)&#xa;+ updateUserStat(id, field, val)&#xa;+ logout()" style="text;align=left;spacingLeft=8;" vertex="1" parent="cls-session"><mxGeometry y="58" width="220" height="202" as="geometry"/></mxCell>

        <!-- SessionModel → User -->
        <mxCell id="e17" style="edgeStyle=none;rounded=0;endArrow=classic;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="cls-session" target="cls-user"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ====== WorksheetModel ====== -->
        <mxCell id="cls-wsm" value="&lt;b&gt;WorksheetModel&lt;/b&gt;" style="swimlane;fillColor=#dc2626;fontColor=#fff;startSize=28;" vertex="1" parent="1"><mxGeometry x="300" y="60" width="240" height="220" as="geometry"/></mxCell>
        <mxCell id="fwm" value="# exercises[], currentIndex&#xa;# correctAnswers, totalAnswers&#xa;# worksheetId, sessionModel" style="text;align=left;spacingLeft=8;" vertex="1" parent="cls-wsm"><mxGeometry y="28" width="240" height="40" as="geometry"/></mxCell>
        <mxCell id="mwm" value="+ getCurrentExercise()&#xa;+ nextExercise()&#xa;+ isCompleted()&#xa;+ recordAnswer(correct)&#xa;+ getScore()&#xa;# _persistProgress()&#xa;# _dispatchStreak()" style="text;align=left;spacingLeft=8;" vertex="1" parent="cls-wsm"><mxGeometry y="68" width="240" height="152" as="geometry"/></mxCell>

        <!-- ====== HardcoreWorksheetModel ====== -->
