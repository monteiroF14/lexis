        <mxCell id="mhc" value="+ nextExercise() (override)&#xa;# _persistProgress() (override)" style="text;align=left;spacingLeft=8;" vertex="1" parent="cls-hc"><mxGeometry y="58" width="240" height="92" as="geometry"/></mxCell>

