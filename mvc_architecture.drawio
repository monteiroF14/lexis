        <mxCell id="html-dash" value="dashboard.html" style="rounded=0;fillColor=#ddd;" vertex="1" parent="1"><mxGeometry x="160" y="140" width="100" height="30" as="geometry"/></mxCell>

        <!-- ====== AUTH VIEWS ====== -->
