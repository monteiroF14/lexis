<mxfile host="Electron">
  <diagram name="Architecture" id="arch">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Legend -->
        <mxCell id="legend-entry" value="Entry point" style="rounded=1;fillColor=#333;fontColor=#fff;" vertex="1" parent="1"><mxGeometry x="20" y="10" width="100" height="30" as="geometry"/></mxCell>
        <mxCell id="legend-view" value="View" style="rounded=1;fillColor=#1a56db;fontColor=#fff;" vertex="1" parent="1"><mxGeometry x="130" y="10" width="70" height="30" as="geometry"/></mxCell>
        <mxCell id="legend-model" value="Model" style="rounded=1;fillColor=#dc2626;fontColor=#fff;" vertex="1" parent="1"><mxGeometry x="210" y="10" width="70" height="30" as="geometry"/></mxCell>
        <mxCell id="legend-util" value="Utility/Data" style="rounded=1;fillColor=#65a30d;fontColor=#fff;" vertex="1" parent="1"><mxGeometry x="290" y="10" width="90" height="30" as="geometry"/></mxCell>

        <!-- ====== ENTRY POINTS ====== -->
        <mxCell id="init" value="init.js&#xa;(landing page)" style="rounded=1;fillColor=#333;fontColor=#fff;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="120" height="50" as="geometry"/></mxCell>
        <mxCell id="dash-init" value="dashboard_init.js&#xa;(main app)" style="rounded=1;fillColor=#333;fontColor=#fff;align=center;" vertex="1" parent="1"><mxGeometry x="200" y="60" width="120" height="50" as="geometry"/></mxCell>
